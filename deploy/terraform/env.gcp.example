# eyeVesa GCP Deployment Configuration
# Copy this file to .env.gcp and fill in your values
# Created by: deploy/scripts/deploy-gcp.sh init

# ── GCP Project ──────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=asia-southeast1
GCP_ENVIRONMENT=production
GCP_DOMAIN=gateway.eyevesa.ai
ARTIFACT_REGISTRY=eyevesa-production

# ── Terraform Variables ──────────────────────────────────────────
TF_VAR_project_id=your-gcp-project-id
TF_VAR_region=asia-southeast1
TF_VAR_environment=production
TF_VAR_domain=gateway.eyevesa.ai
TF_VAR_db_password=CHANGE_ME_USE_STRONG_PASSWORD
TF_VAR_jwt_secret=CHANGE_ME_USE_LONG_RANDOM_STRING
TF_VAR_gateway_ed25519_key=CHANGE_ME_GENERATE_WITH_openssl_genpkey

# ── Optional: Push Notifications ──────────────────────────────────
# SLACK_WEBHOOK_URL=
# PAGERDUTY_INTEGRATION_KEY=
# APNS_KEY_PATH=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# FCM_SERVER_KEY=
# FCM_PROJECT_ID=